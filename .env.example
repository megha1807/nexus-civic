# --- CORE DATABASE ------------------------------------------------
# Get from: https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/nexus-civic

# --- AI SERVICES --------------------------------------------------
# Get from: https://aistudio.google.com -> Get API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Get from: https://elevenlabs.io -> Profile -> API Keys
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
# Get from: ElevenLabs -> Voices -> pick one -> copy ID
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# --- REALTIME / BLOCKCHAIN ---------------------------------------
# Get from: https://spacetimedb.com -> after running: spacetime start
SPACETIMEDB_URI=ws://localhost:3000
# true = use real Solana devnet. false = mock mode (safe for hackathon demo)
SOLANA_ENABLED=false
SOLANA_RPC_URL=https://api.devnet.solana.com
# Generate with: solana-keygen new -> copy the array from ~/.config/solana/devnet.json
SOLANA_WALLET_PRIVATE_KEY=[]
# Set after running: anchor deploy
SOLANA_PROGRAM_ID=

# --- AUTOMATION ---------------------------------------------------
# Get from: https://superplane.dev -> after creating workflows
SUPERPLANE_API_KEY=your_superplane_api_key_here
SUPERPLANE_WORKFLOW_ID_GRIEVANCE=your_workflow_id_here
SUPERPLANE_WORKFLOW_ID_GUARDIAN=your_workflow_id_here
SUPERPLANE_WORKFLOW_ID_DISPATCH=your_workflow_id_here

# --- ARMORIQ (Zero Trust) ----------------------------------------
# Get from: https://armoriq.com -> API Keys
# Leave empty to use local ZTA engine (still fully functional)
ARMORIQ_API_KEY=

# --- PUSH NOTIFICATIONS ------------------------------------------
# Get from: Firebase Console -> Project Settings -> Service Account -> Generate key
# Paste the entire JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- EXTERNAL DATA ------------------------------------------------
# Get from: https://newsapi.org -> free tier
NEWS_API_KEY=your_news_api_key_here
# true = use realistic mock data (no GEE account needed for demo)
GEE_MOCK=true
# Only needed if GEE_MOCK=false
GEE_SERVICE_ACCOUNT_JSON=

# --- CLOUD DEPLOYMENT --------------------------------------------
VULTR_API_KEY=your_vultr_api_key_here

# --- AUTH ---------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_in_production

# --- SERVICE PORTS (change if ports conflict on your machine) ----
GUARDIAN_NET_PORT=3001
PULSE_REPORT_PORT=3002
CIVIC_PULSE_PORT=3003
GIG_FORGE_PORT=3004
NEAR_GIVE_PORT=3005
TERRA_SCAN_PORT=3006
SENTINEL_AI_PORT=3007
VOICE_ASSEMBLY_PORT=3008
LEDGER_CIVIC_PORT=3009
MESH_ALERT_PORT=3010
AURA_ASSIST_PORT=3011
WEB_PORT=3000

# --- CORS ---------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# --- NEXT.JS FRONTEND (public vars - safe to expose) ------------
NEXT_PUBLIC_GUARDIAN_NET_URL=http://localhost:3001
NEXT_PUBLIC_PULSE_REPORT_URL=http://localhost:3002
NEXT_PUBLIC_CIVIC_PULSE_URL=http://localhost:3003
NEXT_PUBLIC_GIG_FORGE_URL=http://localhost:3004
NEXT_PUBLIC_NEAR_GIVE_URL=http://localhost:3005
NEXT_PUBLIC_TERRA_SCAN_URL=http://localhost:3006
NEXT_PUBLIC_SENTINEL_AI_URL=http://localhost:3007
NEXT_PUBLIC_VOICE_ASSEMBLY_URL=http://localhost:3008
NEXT_PUBLIC_LEDGER_CIVIC_URL=http://localhost:3009
NEXT_PUBLIC_MESH_ALERT_URL=http://localhost:3010
NEXT_PUBLIC_AURA_ASSIST_URL=http://localhost:3011
